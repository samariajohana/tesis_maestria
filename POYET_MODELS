        #definimos el modelo xgb que se generará en cada iteración
        xgb= XGBRegressor(objective='reg:absoluteerror', random_state=42)
        
        # definimos grid search 
        grid_search= GridSearchCV(estimator= xgb,
                                  param_grid=param_grid, 
                                  scoring=scoring, 
                                  cv=cv, 
                                  verbose=1, 
                                  n_jobs=-1)
        grid_search.fit(X,y)

        y_pred = cross_val_predict(grid_search.best_estimator_, X, y, cv=cv, n_jobs=-1)

        # almacenamos hiperparámetros y las r2 de cada metabolito 
        r2_scores= r2_score(y, y_pred)
        spearman_corr, spearman_pval= spearmanr(y, y_pred)
        mape= mean_absolute_percentage_error(y, y_pred)
        mae= mean_absolute_error(y, y_pred)
        
        # almacenamos en la lista resultados 
        resultados.append({'metabolito':metabolito, 
                           'hiperparams':grid_search.best_params_, 
                           'R2_enet':r2_scores, 
                           'Spearman':spearman_corr, 
                           'Spearman_pval':spearman_pval, 
                           'mae':mae, 
                           'mape':mape, 
                           'y': y, 
                           'y_pred': y_pred})
    
    # creamos data frame con los resultados 
    modelos_XGB_poyetbio_final= pd.DataFrame(resultados)
    modelos_XGB_poyetbio_final= modelos_XGB_poyetbio_final.sort_values(by='Spearman', ascending=False)
    #modelos_enet_poyetbio_final.to_csv('modelos_XGB_poyetbio_final_featfiltradas.csv')

    return modelos_XGB_poyetbio_final
