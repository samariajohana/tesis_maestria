def modelos_XGB(micro, mtb):
    global modelos_XGB_poyetbio_final
    
    X = micro.copy() # copia para no modificar df original
    X.columns= X.columns.str.replace(r"[\[\]<>]", "", regex=True) # eliminar caracteres especiales

    param_grid = {
    'n_estimators': [50, 100, 200],
    'max_depth': [3, 5, 7],
    'learning_rate': [0.01, 0.1, 0.3],
    'colsample_bytree': [0.8, 1],
    'min_child_weight': [1, 5, 10]
}
    
    # evaluación con CV=5
    cv= KFold(n_splits=5, shuffle=True, random_state=42)
    scoring='neg_mean_absolute_error'

