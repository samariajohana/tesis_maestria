def modelos_ENET(micro, mtb):
    global modelos_enet_poyetbio_final
    
    X = micro.copy() # copia para no modificar df original
    X.columns= X.columns.str.replace(r"[\[\]<>]", "", regex=True) # eliminar caracteres especiales

    param_grid= {
        'alpha': [0.001, 0.01, 0.1, 1, 10],
        'l1_ratio': [0.1, 0.3, 0.5, 0.7, 0.9],
        "fit_intercept": [True, False],
        "selection": ["cyclic", "random"]
    }
    
    # evaluación con CV=10
    cv= KFold(n_splits=10, shuffle=True, random_state=42)
    scoring='neg_mean_absolute_error'

    resultados= []
    
    metabolitos= mtb.columns

    for i, metabolito in enumerate(metabolitos): 
        print(f"Procesando {i+1} / {len(metabolitos)}: {metabolito}")
        y= mtb[metabolito]
    
        # definimos modelo Elastic net 
        enet_model= ElasticNet(random_state=42)
    
        # definimos grid search 
        grid_search= GridSearchCV(estimator= enet_model,
                                  param_grid=param_grid, 
                                  scoring=scoring, 
                                  cv=cv, 
                                  verbose=1, 
                                  n_jobs=-1)
        grid_search.fit(X,y)

        y_pred = cross_val_predict(grid_search.best_estimator_, X, y, cv=cv, n_jobs=-1)

        # almacenamos hiperparámetros y las r2 de cada metabolito 
        r2_scores= r2_score(y, y_pred)
        spearman_corr, spearman_pval= spearmanr(y, y_pred)
        mape= mean_absolute_percentage_error(y, y_pred)
        mae= mean_absolute_error(y, y_pred)
        
        # almacenamos en la lista resultados 
        resultados.append({'metabolito':metabolito, 
                           'hiperparams':grid_search.best_params_, 
                           'R2_enet':r2_scores, 
                           'Spearman':spearman_corr, 
                           'Spearman_pval':spearman_pval, 
                           'mae':mae, 
                           'mape':mape, 
                           'y': y, 
                           'y_pred': y_pred})
    
    # creamos data frame con los resultados 
    modelos_enet_poyetbio_final= pd.DataFrame(resultados)
    modelos_enet_poyetbio_final= modelos_enet_poyetbio_final.sort_values(by='Spearman', ascending=False)
    modelos_enet_poyetbio_final.to_csv('modelos_enet_poyetbio_final_featfiltradas.csv')

    return modelos_enet_poyetbio_final

modelos_ENET(micro,mtb_winsor)

#### RANDOM FOREST ###
def modelos_RF(micro, mtb):
    global modelos_RF_poyetbio

    X = micro.copy() # copia para no modificar df original
    X.columns= X.columns.str.replace(r"[\[\]<>]", "", regex=True) # eliminar caracteres especiales 
    
    # definir parámetros para el Grid Search 
    param_grid = {
        'n_estimators': [20, 50, 100],
        'max_depth': [3, 5, 7],
        'max_features': ['sqrt', 'log2', None],  
        'min_samples_split': [2, 5, 10],
        'min_samples_leaf': [1, 2, 4]
    }
    
    # definimos evaluación con Leave-One-Out
    cv= KFold(n_splits=10, shuffle=True, random_state=42)
    scoring='neg_mean_absolute_error'
    
    # crear lista para almacenar resultados 
    resultados= [] 
    
    # loop for para iterar por cada metabolito del df mtb 
    metabolitos= mtb.columns
    
    for i, metabolito in enumerate(metabolitos):
        print(f"Procesando {i+1} / {len(metabolitos)}: {metabolito}")
        y = mtb[metabolito] 
    
        # definimos modelo RF 
        RF_model= RandomForestRegressor(random_state=42)
    
        # definimos el Grid Search 
        grid_search = GridSearchCV(estimator=RF_model,
                               param_grid=param_grid,
                               scoring=scoring,
                               cv=cv,
                               verbose=1,
                               n_jobs=-1)
        grid_search.fit(X,y)
        
        y_pred = cross_val_predict(grid_search.best_estimator_, X, y, cv=cv, n_jobs=-1)
    
        r2_scores= r2_score(y, y_pred)
        spearman_corr, spearman_pval= spearmanr(y, y_pred)
        mape= mean_absolute_percentage_error(y, y_pred)
        mae= mean_absolute_error(y, y_pred)
        
        # almacenamos en la lista resultados 
        resultados.append({'metabolito':metabolito, 
                           'hiperparams':grid_search.best_params_, 
                           'R2_enet':r2_scores, 
                           'Spearman':spearman_corr, 
                           'Spearman_pval':spearman_pval, 
                           'mae':mae, 
                           'mape':mape, 
                           'y': y, 
                           'y_pred': y_pred})
        
    modelos_RF_poyetbio= pd.DataFrame(resultados)
    modelos_RF_poyetbio= modelos_RF_poyetbio.sort_values(by='Spearman', ascending=False)
    #modelos_RF_poyetbio.to_csv('modelos_RF_poyetbio.csv')
    
    return modelos_RF_poyetbio
modelos_RF(micro, mtb_winsor)

