# function to run Random Forest Regression models
def modelos_RF(micro_df, mtb_df):
    global modelos_RF_t1d
    X= micro_df.copy()
    X.columns= X.columns.str.replace(r"[\[\]<>]", "", regex=True)
    print(len(mtb_df))

    # Grid Search Hyperparms
    param_grid = {
    'n_estimators': [100, 250, 500],
    'max_depth': [None, 5, 10,20],
    'max_features': ['sqrt', 'log2', 0.2],
    'min_samples_split': [2, 5, 10],
    'min_samples_leaf': [1, 2, 4]
    }

    # 10-fold cross validation 
    cv= KFold(n_splits=10, shuffle=True, random_state=42)

    # scoring metric
    scoring = make_scorer(mean_absolute_percentage_error, greater_is_better=False)

    # List to store the reasults
    resultados= []
    metabolitos= mtb_df.columns
    #metabolitos= mtb_df[['Lithocholic acid', 'Deoxycholic acid/Chenodeoxycholic acid']]
    
    # iterate over each metabolite
    for i, metabolito in enumerate(metabolitos): 
        print(f"Procesando {i+1} / {len(metabolitos)}: {metabolito}")
        y = mtb_df[metabolito]
    
        # RF model
        RF_model= RandomForestRegressor(random_state=42)
    
        grid_search = GridSearchCV(estimator=RF_model,
                                   param_grid=param_grid,
                                   scoring=scoring,
                                   cv=cv,
                                   verbose=1,
                                   n_jobs=-1)
        grid_search.fit(X,y)
    
        y_pred = cross_val_predict(grid_search.best_estimator_, X, y, cv=cv, n_jobs=-1)
        
        # performance metrics
        r2_scores= r2_score(y, y_pred)
        spearman_corr, spearman_pval= spearmanr(y, y_pred)
        mape= mean_absolute_percentage_error(y, y_pred)
        mae= mean_absolute_error(y, y_pred)
        diferencia = (y - y_pred).abs()
    
        # store results
        resultados.append({'metabolito': metabolito, 'hiperparams': grid_search.best_params_, 'R2': r2_scores, 'Spearman':spearman_corr,
                               'Spearman_pval': spearman_pval, 'mape':mape, 'mae':mae, 'y': y, 'y_pred': y_pred, 'dif':diferencia})
    
        modelos_RF_t1d= pd.DataFrame(resultados)

# Run models
modelos_RF(genera_2, mtb_2)

